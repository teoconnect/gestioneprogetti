# Per lo sviluppo locale e un test veloce, utilizziamo SQLite.
DATABASE_URL="file:./dev.db"

# Per passare alla produzione usando PostgreSQL, de-commentare la linea seguente:
# DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

APP_USERS="admin:admin123,user:user123"
JWT_SECRET_KEY="super-secret-jwt-key-for-development-only"

# Impostazioni Server SMTP (Mail) per le Notifiche
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"
SMTP_FROM="your-email@example.com"

# URL base dell'applicazione per i link nelle email (es. https://tuo-dominio.com)
APP_URL="http://localhost:3000"
